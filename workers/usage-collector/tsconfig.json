{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "../..",
    "incremental": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/server/jobs/workers/usage-collector/contracts": ["./src/contracts/index.ts"],
      "@/server/jobs/workers/usage-collector/core/*": ["./src/core/*"],
      "@/server/jobs/workers/usage-collector/decoders/*": ["./src/decoders/*"],
      "@/server/jobs/workers/usage-collector/infra/leader-lock": ["./src/infra/leader-lock.ts"],
      "@/server/jobs/workers/usage-collector/sources/resp-queue-source": ["./src/infra/resp-queue-source.ts"],
      "@/server/jobs/workers/usage-collector/repositories/*": ["./src/repositories/*"],
      "@/server/jobs/workers/usage-collector/runner": ["./src/runtime/runner.ts"],
      "@/server/jobs/workers/usage-collector/runtime-main": ["./src/runtime/runtime-main.ts"],
      "@/server/db/generated/prisma/*": ["../../apps/dashboard/src/server/db/generated/prisma/*"],
      "@/server/db/*": ["../../apps/dashboard/src/server/db/*"],
      "@/lib/*": ["../../apps/dashboard/src/lib/*"],
      "@/*": ["./src/*", "../../apps/dashboard/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "node_modules"]
}
