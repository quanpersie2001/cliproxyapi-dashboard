{
  "name": "dashboard",
  "version": "0.2.12",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate",
    "predev": "npm run prisma:generate",
    "dev": "next dev",
    "dev:app": "next dev",
    "dev:collector": "tsx scripts/runtime/dev-collector.ts",
    "dev:embedded": "node scripts/runtime/dev-runner.mjs",
    "prebuild": "npm run prisma:generate",
    "build:collector": "rm -rf dist-collector && tsc -p tsconfig.collector.json && cp scripts/runtime/collector-bootstrap.js dist-collector/collector-bootstrap.js && node scripts/postbuild-collector.cjs",
    "build": "npm run build:collector && next build && rm -rf .next/standalone/apps/dashboard/.next/static && mkdir -p .next/standalone/apps/dashboard/.next && cp -R .next/static .next/standalone/apps/dashboard/.next/static",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "pretest": "npm run prisma:generate",
    "start": "node dist-collector/collector-bootstrap.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:provider-ownership": "tsx src/server/jobs/scripts/migrate-provider-ownership.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "jose": "^6.2.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.1.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
